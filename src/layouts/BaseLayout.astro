---
import "../styles/global.css";
import { SITE, navLinks } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title = SITE.title,
  description = SITE.description,
  canonical,
  image = "/assets/health-dashboard.png",
  type = "website"
} = Astro.props;

const cleanStaticPath = (pathname: string) => {
  if (pathname === "/index.html") return "/";

  const cleanPages = new Set([
    "/about.html",
    "/contact.html",
    "/privacy.html",
    "/disclaimer.html",
    "/editorial-policy.html",
    "/advertising-policy.html",
    "/terms.html",
    "/cookie-policy.html",
    "/review-process.html",
    "/guides.html",
    "/calculator-guide.html",
    "/health-checkup-guide.html",
    "/health-metric-glossary.html",
    "/standards-update-log.html",
    "/health-record-template.html"
  ]);

  return cleanPages.has(pathname) ? pathname.replace(/\.html$/, "") : pathname;
};

const canonicalUrl = canonical ?? new URL(cleanStaticPath(Astro.url.pathname), SITE.url).toString();
const imageUrl = new URL(image, SITE.url).toString();
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT || "ca-pub-1441018945572157";
const currentPath = Astro.url.pathname;
const orgJson = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  email: SITE.email
};
const websiteJson = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.title,
  url: SITE.url,
  inLanguage: "ko-KR",
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE.url}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="naver-site-verification" content="508231a30598d9841c7c252832e9fc2ce42bec05" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="theme-color" content="#f7f9f8" />
    {adsenseClient ? <meta name="google-adsense-account" content={adsenseClient} /> : null}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {
      adsenseClient ? (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      ) : null
    }
    <script type="application/ld+json" set:html={JSON.stringify(orgJson)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJson)} />
  </head>
  <body>
    <a class="skip-link" href="#content">본문으로 이동</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/" aria-label="WELLBEEP 홈">
          <span class="brand__mark" aria-hidden="true">W</span>
          <span class="brand__text">
            <span>{SITE.name}</span>
            <small>건강 계산기</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="주요 메뉴">
          {
            navLinks.map((item) => (
              <a
                href={item.href}
                aria-current={currentPath === item.href ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner wrap">
        <div>
          <h2>{SITE.title}</h2>
          <p>
            계산 결과와 설명은 일반적인 건강 정보 참고용이며, 진단이나 치료 판단을
            대신하지 않습니다. 증상이나 이상 수치가 지속되면 의료 전문가와 상담하세요.
          </p>
        </div>
        <nav class="footer-links" aria-label="하단 메뉴">
          <a href="/about">소개</a>
          <a href="/guides">원본 가이드</a>
          <a href="/calculator-guide">사용법</a>
          <a href="/health-checkup-guide">검진 해석</a>
          <a href="/health-metric-glossary">용어집</a>
          <a href="/health-record-template">기록표</a>
          <a href="/health-resources">참고 기관</a>
          <a href="/calculator-methodology">계산 기준</a>
          <a href="/standards-update-log">업데이트 로그</a>
          <a href="/contact">문의</a>
          <a href="/privacy">개인정보처리방침</a>
          <a href="/terms">이용약관</a>
          <a href="/cookie-policy">쿠키 정책</a>
          <a href="/disclaimer">면책사항</a>
          <a href="/editorial-policy">편집 원칙</a>
          <a href="/review-process">작성·검수 기준</a>
          <a href="/advertising-policy">광고 정책</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
