---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";

const canonical = `${SITE.url}/standards-update-log`;
const title = `기준 업데이트 로그 | ${SITE.name}`;
const description =
  "Health Care 계산기 기준, 참고 자료, 정책 문서 업데이트 이력을 정리한 운영 로그입니다.";
const entries = [
  {
    date: "2026-07-18",
    title: "필수 신뢰 문서 확장",
    body: "이용약관, 쿠키 정책, 작성·검수 기준 페이지를 추가하고 개인정보처리방침, 광고 정책, 면책사항, 푸터와 사이트맵에 연결했습니다.",
    links: ["/terms", "/cookie-policy", "/review-process", "/privacy"]
  },
  {
    date: "2026-07-18",
    title: "계산기 심화 보강",
    body: "핵심 계산기 심화 해설, 예시 계산, 시각 해석표, 검진 허브, 용어집, 기록표 페이지를 추가했습니다.",
    links: ["/health-checkup-guide", "/health-metric-glossary", "/health-record-template"]
  },
  {
    date: "2026-07-18",
    title: "시각 정보 레이어 추가",
    body: "전체 계산기 페이지에 카테고리별 핵심 지표 카드, 결과 해석 표, 3단계 흐름도를 추가했습니다.",
    links: ["/calculator-guide", "/calculator-methodology"]
  },
  {
    date: "2026-07-18",
    title: "정책·운영 문서 보강",
    body: "광고 정책, 개인정보처리방침, 면책사항, 편집 원칙, 문의 페이지의 운영 절차와 안전 안내를 확장했습니다.",
    links: ["/advertising-policy", "/privacy", "/editorial-policy"]
  },
  {
    date: "2026-07-18",
    title: "계산기 산출 방식 문서 공개",
    body: "계산식 선정, 결과 해석, 검수와 정정 절차를 설명하는 방법론 문서를 추가했습니다.",
    links: ["/calculator-methodology"]
  },
  {
    date: "2026-03-12",
    title: "Health Care 계산기 아카이브 시작",
    body: "생활 건강 지표를 한국어 계산기와 해설로 정리하는 사이트 운영을 시작했습니다.",
    links: ["/about"]
  }
];
const logJson = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "기준 업데이트 로그",
  description,
  url: canonical,
  inLanguage: "ko-KR"
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Update Log</p>
      <h1>기준 업데이트 로그</h1>
      <p>
        Health Care가 계산식, 참고 자료, 정책 문서, 사용자 안내를 어떻게 보강했는지 기록합니다.
        이 로그는 독자가 사이트 운영 흐름을 확인할 수 있도록 공개하는 관리 문서입니다.
      </p>
      <div class="policy-meta" aria-label="업데이트 로그 요약">
        <span>운영 시작일 {SITE.startedAt}</span>
        <span>최종 정책 수정일 {SITE.lastPolicyUpdate}</span>
        <span>정정 요청 공개 경로</span>
      </div>
    </div>
  </section>

  <article class="page-content page-content--wide">
    <p class="lead">
      건강 기준과 참고 자료는 시간이 지나며 바뀔 수 있습니다. Health Care는 계산기가 진단이나 처방처럼 보이지 않도록
      산출 기준, 주의 문구, 참고 링크, 정책 문서를 함께 관리합니다.
    </p>

    <section class="resource-section">
      <h2>업데이트 이력</h2>
      <div class="timeline-list">
        {entries.map((entry) => (
          <article class="timeline-item">
            <time datetime={entry.date}>{entry.date}</time>
            <h3>{entry.title}</h3>
            <p>{entry.body}</p>
            <div class="timeline-links">
              {entry.links.map((href) => <a href={href}>{href.replace("/", "") || "home"}</a>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="resource-section">
      <h2>오류 제보가 들어오면 확인하는 항목</h2>
      <ol class="policy-list">
        <li>페이지 주소와 입력값, 예상 결과를 기준으로 재현 여부를 확인합니다.</li>
        <li>공식 기준이나 참고 자료가 바뀐 경우 관련 계산기와 허브 문서를 함께 점검합니다.</li>
        <li>수정이 필요한 경우 계산식, 안내 문구, FAQ, 참고 링크, 사이트맵 반영을 확인합니다.</li>
      </ol>
      <p>
        제보는 <a href="/contact">문의하기</a>에서 접수하며, 계산식 검수 기준은
        <a href="/calculator-methodology">계산기 산출 방식 및 검수 기준</a>에 정리되어 있습니다.
      </p>
    </section>

    <section class="resource-section">
      <h2>문서 관리 원칙</h2>
      <p>
        정책 문서와 계산기 문서는 따로 움직이지 않도록 관리합니다. 계산식이나 참고 기관 링크가 바뀌면
        관련 계산기, 허브 페이지, 면책 안내, 작성·검수 기준, 사이트맵까지 함께 확인해 사용자가 같은 기준을 따라 읽을 수 있게 합니다.
      </p>
      <p>
        광고와 개인정보 관련 문서는 사이트 운영 조건이 달라질 때 우선 검토합니다. 새 광고 기술이나 외부 서비스가 추가되면
        개인정보처리방침, 쿠키 정책, 광고 정책의 안내가 서로 모순되지 않는지 확인합니다.
      </p>
    </section>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(logJson)} />
</BaseLayout>
